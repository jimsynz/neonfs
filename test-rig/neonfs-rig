#!/usr/bin/env bash
# NeonFS QEMU test rig — spin up VM nodes, install neonfs_omnibus, form a cluster.
# See test-rig/README.md for details. Run `./neonfs-rig help` for commands.
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib/rig.sh"

cmd_up() {
  require_tools
  ensure_image
  ensure_debs
  ensure_ssh_key

  local i
  for i in $(seq 1 "${NODES}"); do
    create_node_disks "$i"
    write_seed "$i"
    boot_node "$i"
  done
  for i in $(seq 1 "${NODES}"); do
    wait_ssh "$i"
    wait_cloud_init "$i"
    provision_node "$i"
  done

  cluster_bootstrap

  echo
  log "cluster '${CLUSTER_NAME}' is up (${NODES} node(s))"
  cmd_status
}

cmd_boot() {
  require_tools; ensure_image; ensure_debs; ensure_ssh_key
  local i
  for i in $(seq 1 "${NODES}"); do
    create_node_disks "$i"; write_seed "$i"; boot_node "$i"
  done
  for i in $(seq 1 "${NODES}"); do
    wait_ssh "$i"; wait_cloud_init "$i"; provision_node "$i"
  done
  log "${NODES} node(s) booted and provisioned (cluster not initialised — run 'init')"
}

cmd_init() { cluster_bootstrap; }

# Standalone interface-node join acceptance (#1163): boot an extra VM with
# only neonfs-common + neonfs-cli + neonfs-nfs, join it to the running
# cluster with an invite token, and verify registration + NFS serving +
# daemon-restart survivability. Requires a cluster from `up` first.
cmd_iface_join() {
  require_tools
  ensure_image
  ensure_debs
  ensure_ssh_key
  node_running 1 || die "no running cluster — bring one up first with './neonfs-rig up'"

  local i="${IFACE_INDEX}"
  create_node_disks "$i"
  write_seed "$i"
  boot_node "$i"
  wait_ssh "$i"
  wait_cloud_init "$i"
  provision_iface_node "$i"

  iface_join_scenario
}

BENCH_BIG_FILE="neonfs_bench_big"
BENCH_SCRATCH=".neonfs_bench"

# Per-interface bench setup. Each brings the interface up (idempotently),
# pre-stages the large source file so read/stat/range ops have a target, and
# returns 0 only when the interface is ready to benchmark. Mirrors the drive
# path test-rig/lib/acceptance.sh uses for each interface.
bench_setup_fuse() {
  volume_present "${ACCEPT_VOL}" || return 1
  if ! node_ssh 1 "grep -q ' ${FUSE_MNT} ' /proc/mounts" 2>/dev/null; then
    node_ssh 1 "sudo install -d -o neonfs -g neonfs ${FUSE_MNT}" >/dev/null 2>&1 || return 1
    node_cli 1 "fuse mount ${ACCEPT_VOL} ${FUSE_MNT}" >/dev/null 2>&1 || return 1
  fi
  node_ssh 1 "sudo -u neonfs bash -c 'mkdir -p ${FUSE_MNT}/${BENCH_SCRATCH} && cp -f /tmp/${BENCH_BIG_FILE} ${FUSE_MNT}/${BENCH_BIG_FILE}'" >/dev/null 2>&1
}

bench_setup_nfs() {
  volume_present "${ACCEPT_VOL}" || return 1
  node_cli 1 "nfs export ${ACCEPT_VOL}" >/dev/null 2>&1 || true
  if ! node_ssh 1 "mount | grep -q '${NFS_MNT}'" 2>/dev/null; then
    node_ssh 1 "sudo mkdir -p ${NFS_MNT} && sudo mount -t nfs -o nfsvers=3,proto=tcp,nolock,port=2049,mountport=2049 127.0.0.1:/${ACCEPT_VOL} ${NFS_MNT}" >/dev/null 2>&1 || return 1
  fi
  node_ssh 1 "sudo bash -c 'mkdir -p ${NFS_MNT}/${BENCH_SCRATCH} && cp -f /tmp/${BENCH_BIG_FILE} ${NFS_MNT}/${BENCH_BIG_FILE}'" >/dev/null 2>&1
}

bench_stage_s3() {
  node_ssh 1 "command -v s3cmd >/dev/null 2>&1" 2>/dev/null || return 1
  node_ssh 1 "s3cmd ${S3_FLAGS} put /tmp/${BENCH_BIG_FILE} s3://${ACCEPT_VOL}/${BENCH_BIG_FILE}" >/dev/null 2>&1
}

bench_stage_webdav() {
  node_ssh 1 "curl -sf ${DAV_AUTH} -T /tmp/${BENCH_BIG_FILE} ${DAV_BASE}/${ACCEPT_VOL}/${BENCH_BIG_FILE} -o /dev/null" >/dev/null 2>&1
}

BENCH_DOCKER_CONTAINER="neonfs-bench"
BENCH_DOCKER_VOL="bench_docker"

# Warm Docker container with a NeonFS volume attached at /data (#1533). Started
# once here so the benchmarked ops (docker exec) don't pay container-spawn cost.
bench_setup_docker() {
  node_ssh 1 "command -v docker >/dev/null 2>&1 && sudo test -S ${DOCKER_SOCK}" 2>/dev/null || return 1
  node_ssh 1 "sudo systemctl is-active --quiet docker || sudo systemctl start docker" 2>/dev/null || true
  node_ssh 1 "test -f /etc/docker/plugins/neonfs.spec" 2>/dev/null || return 1
  node_ssh 1 "sudo docker pull busybox:latest >/dev/null 2>&1" || return 1
  node_ssh 1 "sudo docker volume inspect ${BENCH_DOCKER_VOL} >/dev/null 2>&1 || sudo docker volume create -d neonfs --opt durability=1 ${BENCH_DOCKER_VOL} >/dev/null" || return 1
  node_ssh 1 "sudo docker rm -f ${BENCH_DOCKER_CONTAINER} >/dev/null 2>&1 || true
    sudo docker run -d --name ${BENCH_DOCKER_CONTAINER} -v ${BENCH_DOCKER_VOL}:/data busybox sleep infinity >/dev/null" || return 1
  node_ssh 1 "sudo docker exec ${BENCH_DOCKER_CONTAINER} dd if=/dev/zero of=/data/${BENCH_BIG_FILE} bs=1M count=${big_mib} 2>/dev/null" || return 1
}

# Warm throwaway containerd wired to the NeonFS content proxy (#1533), mirroring
# acceptance.sh's s_containerd_content config but kept running (PID recorded for
# teardown). Pre-stages a blob and echoes "<grpc-socket>\t<digest>".
bench_setup_containerd() {
  node_ssh 1 "command -v containerd >/dev/null 2>&1 && command -v ctr >/dev/null 2>&1 && sudo test -S ${CONTAINERD_SOCK}" 2>/dev/null || return 1
  node_cli 1 "volume list" 2>/dev/null | grep -qE "^${CONTAINERD_VOL}[[:space:]]" \
    || node_cli 1 "volume create ${CONTAINERD_VOL} --replicas ${REPLICAS}" >/dev/null 2>&1 || true

  local out
  out=$(node_ssh 1 "sudo bash -s ${CONTAINERD_SOCK} ${big_mib}" <<'REMOTE'
set -e
PROXY_SOCK="$1"; BIG_MIB="$2"
TMP=/tmp/neonfs-bench-ctrd
rm -rf "$TMP"; mkdir -p "$TMP/root" "$TMP/state"
GRPC="$TMP/containerd.sock"
cat > "$TMP/config.toml" <<CFG
version = 2
root = "$TMP/root"
state = "$TMP/state"
disabled_plugins = ["io.containerd.grpc.v1.cri", "io.containerd.content.v1.content"]
[grpc]
address = "$GRPC"
[ttrpc]
address = "$GRPC.ttrpc"
[proxy_plugins]
  [proxy_plugins.neonfs]
  type = "content"
  address = "$PROXY_SOCK"
CFG
nohup containerd --config "$TMP/config.toml" > "$TMP/containerd.log" 2>&1 &
echo $! > "$TMP/pid"
for _ in $(seq 1 50); do [ -S "$GRPC" ] && break; sleep 0.2; done
[ -S "$GRPC" ] || { echo "containerd grpc never came up" >&2; tail -20 "$TMP/containerd.log" >&2; exit 1; }
dd if=/dev/urandom of="$TMP/blob" bs=1M count="$BIG_MIB" 2>/dev/null
D="sha256:$(sha256sum "$TMP/blob" | awk '{print $1}')"
ctr --address "$GRPC" --namespace bench content ingest --expected-digest "$D" prestage < "$TMP/blob" >/dev/null
printf '%s\t%s\n' "$GRPC" "$D"
REMOTE
) || return 1

  BENCH_CONTAINERD_GRPC=$(echo "${out}" | tail -1 | cut -f1)
  BENCH_CONTAINERD_DIGEST=$(echo "${out}" | tail -1 | cut -f2)
  [ -n "${BENCH_CONTAINERD_GRPC}" ] && [ -n "${BENCH_CONTAINERD_DIGEST}" ]
}

# Best-effort teardown of the warm container-runtime daemons (#1533).
bench_teardown_containers() {
  node_ssh 1 "sudo docker rm -f ${BENCH_DOCKER_CONTAINER} >/dev/null 2>&1 || true" 2>/dev/null || true
  node_ssh 1 "[ -f /tmp/neonfs-bench-ctrd/pid ] && sudo kill \$(cat /tmp/neonfs-bench-ctrd/pid) 2>/dev/null || true; sudo rm -rf /tmp/neonfs-bench-ctrd" 2>/dev/null || true
}

# Benchee benchmark harness (#1520 foundation, #1521 canonical op set). Sets up
# every file-serving interface it can (FUSE, NFS, S3, WebDAV) on the running
# cluster — reusing acceptance.sh's credential/mount setup — then runs the
# Elixir/benchee suite in test-rig/bench, which drives the canonical op set over
# the rig's own SSH path and writes SHA-/config-stamped JSON/CSV/HTML + a
# printed summary. Interfaces it can't set up are logged and skipped. Requires a
# cluster from `up` first.
cmd_bench() {
  # `--rev <sha>`: check out, build, and boot a specific revision before
  # benchmarking, so each manual `git bisect` step over an auto-raised
  # regression's range (#1524) is a single command (#1525). The original ref is
  # restored on exit. Auto-bisecting full-VM benchmarks is too slow, so bisect
  # stays manual — this just makes each step one command.
  local rev=""
  if [ "${1:-}" = "--rev" ]; then
    rev="${2:-}"
    shift 2 || true
    [ -n "${rev}" ] || die "--rev requires a commit-ish (e.g. './neonfs-rig bench --rev <sha>')"
  fi

  command -v mix >/dev/null 2>&1 || die "mix (Elixir) not found on the rig host — needed to run the benchee harness"

  if [ -n "${rev}" ]; then
    local orig
    orig="$(git -C "${REPO_ROOT}" symbolic-ref --quiet --short HEAD || git -C "${REPO_ROOT}" rev-parse HEAD)"
    # shellcheck disable=SC2064
    trap "git -C '${REPO_ROOT}' checkout --quiet '${orig}'" EXIT
    log "bench --rev: checking out '${rev}' (was '${orig}')"
    git -C "${REPO_ROOT}" checkout --quiet "${rev}" \
      || die "checkout '${rev}' failed (a clean working tree is required)"
    log "rebooting the rig on '${rev}' (fresh build)"
    cmd_clean
    cmd_up
  else
    node_running 1 || die "no running cluster — bring one up first with './neonfs-rig up' (or pass '--rev <sha>')"
  fi

  # ACCEPT_VOL must be set before sourcing so acceptance.sh's derived mount
  # paths (FUSE_MNT/NFS_MNT) follow the bench volume.
  export ACCEPT_VOL="${BENCH_VOLUME:-bench}"
  # shellcheck source=lib/acceptance.sh
  source "${RIG_ROOT}/lib/acceptance.sh"

  local big_mib="${BENCH_BIG_MIB:-64}"

  if ! node_cli 1 "volume list" 2>/dev/null | grep -qE "^${ACCEPT_VOL}[[:space:]]"; then
    log "creating bench volume '${ACCEPT_VOL}' (replicas ${REPLICAS}, compression ${COMPRESSION}, encryption ${ENCRYPTION})"
    node_cli 1 "volume create ${ACCEPT_VOL} --replicas ${REPLICAS} $(codec_create_flags)" >/dev/null
    apply_initial_tier 1 "${ACCEPT_VOL}"
  fi

  log "staging ${big_mib}MiB source file on node 1"
  node_ssh 1 "dd if=/dev/zero of=/tmp/${BENCH_BIG_FILE} bs=1M count=${big_mib} 2>/dev/null"

  local sha; sha="$(cd "${REPO_ROOT}" && git rev-parse --short HEAD 2>/dev/null || echo unknown)"
  local -a e=(
    "BENCH_RIG=${RIG_ROOT}/neonfs-rig" "BENCH_NODE=1" "BENCH_VOLUME=${ACCEPT_VOL}"
    "BENCH_BIG_SIZE=$((big_mib * 1048576))" "BENCH_SHA=${sha}"
    "BENCH_NODES=${NODES}" "BENCH_REPLICAS=${REPLICAS}" "BENCH_DRIVES_PER_NODE=${DRIVES_PER_NODE}"
    "BENCH_CONFIG_LABEL=${BENCH_CONFIG_LABEL:-}"
    "BENCH_COMPRESSION=${COMPRESSION}" "BENCH_ENCRYPTION=${ENCRYPTION}" "BENCH_TIER=${INITIAL_TIER:-}"
  )

  if bench_setup_fuse; then e+=("BENCH_FUSE_MOUNT=${FUSE_MNT}"); log "interface fuse: ready (${FUSE_MNT})"; else warn "interface fuse: unavailable — skipping"; fi
  if bench_setup_nfs;  then e+=("BENCH_NFS_MOUNT=${NFS_MNT}");   log "interface nfs: ready (${NFS_MNT})";  else warn "interface nfs: unavailable — skipping";  fi

  # S3 and WebDAV share one credential (acceptance.sh's s_s3_setup sets
  # S3_FLAGS + DAV_AUTH). s3cmd has no byte-range GET, so s3/range_read is
  # reported as a no-op.
  if s_s3_setup >/dev/null 2>&1 && [ -n "${S3_FLAGS}" ]; then
    if bench_stage_s3;     then e+=("BENCH_S3_FLAGS=${S3_FLAGS}"); log "interface s3: ready"; else warn "interface s3: staging failed — skipping"; fi
    if bench_stage_webdav; then e+=("BENCH_DAV_AUTH=${DAV_AUTH}" "BENCH_DAV_BASE=${DAV_BASE}"); log "interface webdav: ready"; else warn "interface webdav: staging failed — skipping"; fi
  else
    warn "interface s3/webdav: credential setup failed — skipping both"
  fi

  if bench_setup_docker; then e+=("BENCH_DOCKER_CONTAINER=${BENCH_DOCKER_CONTAINER}"); log "interface docker: ready"; else warn "interface docker: unavailable — skipping"; fi
  if bench_setup_containerd; then e+=("BENCH_CONTAINERD_GRPC=${BENCH_CONTAINERD_GRPC}" "BENCH_CONTAINERD_DIGEST=${BENCH_CONTAINERD_DIGEST}"); log "interface containerd: ready"; else warn "interface containerd: unavailable — skipping"; fi

  cd "${RIG_ROOT}/bench"
  mix deps.get --quiet
  log "running benchee harness (sha ${sha}, ${NODES} node(s), replicas ${REPLICAS})"
  local rc=0
  env "${e[@]}" mix run -e "NeonFS.Bench.run()" || rc=$?
  bench_teardown_containers
  return "${rc}"
}

# Standard cluster-config benchmark matrix (#1522). Each config is a full
# boot → bench → teardown cycle (node counts differ), reusing up/bench/down.
# Every run is tagged with its config label (recorded in meta.json and the
# result dir name), on top of the NODES/REPLICAS the foundation already stamps.
# DRIVES_PER_NODE stays at its default; codec/tiering axes are out of scope
# (deferred #1497).
cmd_bench_matrix() {
  command -v mix >/dev/null 2>&1 || die "mix (Elixir) not found on the rig host — needed to run the benchee harness"

  # label NODES REPLICAS
  local -a configs=(
    "baseline 1 1"
    "durable 3 3"
    "spread 3 1"
  )

  local cfg label
  for cfg in "${configs[@]}"; do
    read -r label NODES REPLICAS <<<"${cfg}"
    export NODES REPLICAS
    log "=== matrix config '${label}' (NODES=${NODES} REPLICAS=${REPLICAS}) ==="
    cmd_clean
    cmd_up
    BENCH_CONFIG_LABEL="${label}" cmd_bench
  done

  cmd_down
  log "matrix complete — per-config results under ${RIG_ROOT}/bench/results/ (config_label in meta.json)"
}

cmd_ssh() {
  local i="${1:-1}"; shift || true
  node_ssh "$i" "$@"
}

cmd_cli() {
  local i="1"
  if [[ "${1:-}" =~ ^[0-9]+$ ]]; then i="$1"; shift; fi
  [ "${1:-}" = "--" ] && shift
  node_cli "$i" "$*"
}

cmd_status() {
  local i
  echo "nodes:"
  for i in $(discovered_nodes); do
    if node_running "$i"; then
      printf '  node %s  %-18s ssh 127.0.0.1:%s  [running]\n' \
        "$i" "$(node_erl "$i")" "$(node_ssh_port "$i")"
    else
      printf '  node %s  %-18s [stopped]\n' "$i" "$(node_erl "$i")"
    fi
  done
  if node_running 1; then
    echo; echo "cluster status (node 1):"
    node_cli 1 "cluster status" 2>/dev/null || warn "cluster not initialised yet"
    echo; echo "volumes:"
    node_cli 1 "volume list" 2>/dev/null || true
  fi
}

cmd_down() {
  local i
  for i in $(discovered_nodes); do stop_node "$i"; done
}

cmd_clean() {
  cmd_down
  log "removing per-cluster runtime state (${RUN_DIR})"
  rm -rf "${RUN_DIR}"
}

cmd_help() {
  cat <<EOF
NeonFS QEMU test rig

Usage: ./neonfs-rig <command> [args]

Commands:
  up                 Boot NODES VMs, install neonfs_omnibus, form a cluster, create a volume
  boot               Boot + provision VMs only (skip cluster init)
  init               Initialise/join the cluster on already-provisioned VMs
  iface-join         Boot an interface-only VM (neonfs-nfs) and join it via invite token (#1163)
  bench [--rev <sha>]  Run the benchee suite against the running cluster; --rev checks out/builds/boots that revision first (for bisect)
  bench-matrix       Boot/bench/teardown across the standard cluster-config matrix (baseline/durable/spread)
  status             Show VM and cluster status
  ssh <n> [cmd...]   SSH into node <n> (default 1)
  cli <n> -- <args>  Run the neonfs CLI on node <n>, e.g. cli 1 -- volume list
  down               Stop all VMs (keep disks)
  clean              Stop all VMs and delete runtime state (disks, seeds, ssh key)
  help               This message

Key environment variables (defaults):
  NODES=${NODES}             DRIVES_PER_NODE=${DRIVES_PER_NODE}      DRIVE_SIZE=${DRIVE_SIZE}
  ROOT_SIZE=${ROOT_SIZE}        VM_MEM=${VM_MEM}            VM_CPUS=${VM_CPUS}
  REPLICAS=${REPLICAS}              CLUSTER_NAME=${CLUSTER_NAME}      VOLUME_NAME=${VOLUME_NAME}
  DIST_PORT=${DIST_PORT}         SSH_BASE_PORT=${SSH_BASE_PORT}

Examples:
  ./neonfs-rig up                 # single-node cluster
  NODES=3 ./neonfs-rig up         # three-node cluster (replicas=3)
  ./neonfs-rig cli 1 -- volume list
  ./neonfs-rig down
EOF
}

main() {
  local cmd="${1:-help}"; shift || true
  case "${cmd}" in
    up)     cmd_up "$@" ;;
    boot)   cmd_boot "$@" ;;
    init)   cmd_init "$@" ;;
    iface-join) cmd_iface_join "$@" ;;
    bench)  cmd_bench "$@" ;;
    bench-matrix) cmd_bench_matrix "$@" ;;
    status) cmd_status "$@" ;;
    ssh)    cmd_ssh "$@" ;;
    cli)    cmd_cli "$@" ;;
    down)   cmd_down "$@" ;;
    clean)  cmd_clean "$@" ;;
    help|-h|--help) cmd_help ;;
    *)      die "unknown command '${cmd}' (try: ./neonfs-rig help)" ;;
  esac
}

main "$@"
