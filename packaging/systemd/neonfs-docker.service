[Unit]
Description=NeonFS Docker VolumeDriver Plugin
After=network.target docker.service
Wants=docker.service
Documentation=https://neonfs.dev/docs

[Service]
Type=notify
User=neonfs
Group=neonfs
ExecStart=/usr/bin/neonfs-docker-daemon start
ExecStop=/usr/bin/neonfs-docker-daemon stop
Restart=on-failure
RestartSec=5
TimeoutStartSec=60
# Must exceed the in-flight drain deadline (~25s; see `:drain_deadline_ms` /
# `NEONFS_*_DRAIN_DEADLINE_MS`) plus headroom for the core final-metadata
# snapshot, else systemd SIGKILLs the BEAM mid-drain (#1385). Bump both
# together if either changes.
TimeoutStopSec=45

EnvironmentFile=-/etc/neonfs/neonfs.conf

RuntimeDirectory=neonfs
StateDirectory=neonfs

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
# /var/lib/neonfs holds the cookie + TLS material shared with the core daemon.
# The volume plugin socket lives in /run/neonfs (covered by RuntimeDirectory
# above); dockerd discovers it via /etc/docker/plugins/neonfs.spec.
ReadWritePaths=/var/lib/neonfs

# This unit creates host-visible volume mounts on dockerd's behalf. The
# default mount-namespace propagation under PrivateTmp/ProtectSystem/
# ProtectHome is slave, so mounts created inside the unit don't escape
# to the host namespace where dockerd's containers can pick them up.
# `shared` propagates the unit's mounts outwards. (#758)
MountFlags=shared

[Install]
WantedBy=multi-user.target
