#!/bin/bash
# NeonFS containerd plugin daemon wrapper script
# This script provides systemd-compatible start/stop commands for the neonfs_containerd release

set -e

# Source shared TLS distribution functions
. "${NEONFS_TLS_COMMON:-/usr/lib/neonfs/neonfs-tls-common.sh}"

# Default paths (can be overridden by environment variables)
RELEASE_ROOT="${RELEASE_ROOT:-/usr/lib/neonfs/containerd}"
RELEASE_NAME="${RELEASE_NAME:-neonfs_containerd}"
NEONFS_DATA_DIR="${NEONFS_DATA_DIR:-/var/lib/neonfs}"
DEFAULT_HOST="$(hostname -f 2>/dev/null || hostname)"
RELEASE_NODE="${NEONFS_CONTAINERD_NODE:-${RELEASE_NODE:-neonfs_containerd@${DEFAULT_HOST}}}"
RELEASE_COOKIE_PATH="${RELEASE_COOKIE_PATH:-/var/lib/neonfs/.erlang.cookie}"
NEONFS_CORE_NODE="${NEONFS_CORE_NODE:-neonfs_core@${DEFAULT_HOST}}"
CONTAINERD_PLUGIN_DIR="${CONTAINERD_PLUGIN_DIR:-/run/containerd/proxy-plugins}"

# Generate and persist the Erlang distribution port
ensure_dist_port() {
    local port_file="${NEONFS_DATA_DIR}/meta/dist_port"
    mkdir -p "${NEONFS_DATA_DIR}/meta"

    if [ -n "${NEONFS_DIST_PORT}" ]; then
        echo "${NEONFS_DIST_PORT}" > "${port_file}"
    elif [ -f "${port_file}" ]; then
        export NEONFS_DIST_PORT=$(cat "${port_file}")
    else
        export NEONFS_DIST_PORT=$((49152 + RANDOM % 16383))
        echo "${NEONFS_DIST_PORT}" > "${port_file}"
    fi
}

# Verify cookie exists (should be created by core daemon)
ensure_cookie() {
    if [ ! -f "${RELEASE_COOKIE_PATH}" ]; then
        echo "Error: Erlang cookie not found at ${RELEASE_COOKIE_PATH}"
        echo "Ensure neonfs-core.service is running first, or create a cookie manually."
        exit 1
    fi
}

# Ensure the containerd plugin socket directory exists with the right
# perms. The package's systemd unit grants ReadWritePaths so this is a
# best-effort `mkdir -p` for fresh installs where containerd hasn't yet
# created the directory itself.
ensure_plugin_dir() {
    if [ ! -d "${CONTAINERD_PLUGIN_DIR}" ]; then
        mkdir -p "${CONTAINERD_PLUGIN_DIR}"
        if [ "$EUID" -eq 0 ]; then
            chown root:root "${CONTAINERD_PLUGIN_DIR}"
            chmod 0755 "${CONTAINERD_PLUGIN_DIR}"
        fi
    fi
}

# Write runtime information for CLI discovery
write_runtime_info() {
    local runtime_dir="${RUNTIME_DIR:-/run/neonfs}"
    mkdir -p "${runtime_dir}"

    echo "${RELEASE_NODE}" > "${runtime_dir}/containerd_node_name"
    echo "${NEONFS_CORE_NODE}" > "${runtime_dir}/core_node_name"
    echo "${NEONFS_DIST_PORT}" > "${runtime_dir}/dist_port"
    echo $$ > "${runtime_dir}/containerd.pid"

    # Set ownership if running as root
    if [ "$EUID" -eq 0 ]; then
        chown -R neonfs:neonfs "${runtime_dir}"
    fi
}

# Start the daemon
start_daemon() {
    ensure_cookie
    ensure_dist_port
    ensure_local_tls
    ensure_plugin_dir
    write_runtime_info

    # Start the release in foreground mode (systemd will manage daemonization)
    exec "${RELEASE_ROOT}/bin/${RELEASE_NAME}" start
}

# Stop the daemon gracefully
stop_daemon() {
    "${RELEASE_ROOT}/bin/${RELEASE_NAME}" stop
}

# Get daemon status
status_daemon() {
    "${RELEASE_ROOT}/bin/${RELEASE_NAME}" pid
}

# Main command dispatcher
case "$1" in
    start)
        start_daemon
        ;;
    stop)
        stop_daemon
        ;;
    status)
        status_daemon
        ;;
    *)
        echo "Usage: $0 {start|stop|status}"
        exit 1
        ;;
esac
