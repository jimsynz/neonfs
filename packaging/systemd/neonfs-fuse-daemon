#!/bin/bash
# NeonFS FUSE daemon wrapper script
# This script provides systemd-compatible start/stop commands for the neonfs_fuse release

set -e

# Default paths (can be overridden by environment variables)
RELEASE_ROOT="${RELEASE_ROOT:-/usr/lib/neonfs/fuse}"
RELEASE_NAME="${RELEASE_NAME:-neonfs_fuse}"
NEONFS_DATA_DIR="${NEONFS_DATA_DIR:-/var/lib/neonfs}"
DEFAULT_HOST="$(hostname -f 2>/dev/null || hostname)"
RELEASE_NODE="${NEONFS_FUSE_NODE:-${RELEASE_NODE:-neonfs_fuse@${DEFAULT_HOST}}}"
RELEASE_COOKIE_PATH="${RELEASE_COOKIE_PATH:-/var/lib/neonfs/.erlang.cookie}"
NEONFS_CORE_NODE="${NEONFS_CORE_NODE:-neonfs_core@${DEFAULT_HOST}}"

# Verify cookie exists (should be created by core daemon)
ensure_cookie() {
    if [ ! -f "${RELEASE_COOKIE_PATH}" ]; then
        echo "Error: Erlang cookie not found at ${RELEASE_COOKIE_PATH}"
        echo "Ensure neonfs-core.service is running first."
        exit 1
    fi
}

# Write runtime information for CLI discovery
write_runtime_info() {
    local runtime_dir="${RUNTIME_DIR:-/run/neonfs}"
    mkdir -p "${runtime_dir}"

    echo "${RELEASE_NODE}" > "${runtime_dir}/fuse_node_name"
    echo "${NEONFS_CORE_NODE}" > "${runtime_dir}/core_node_name"
    echo $$ > "${runtime_dir}/fuse.pid"

    # Set ownership if running as root
    if [ "$EUID" -eq 0 ]; then
        chown -R neonfs:neonfs "${runtime_dir}"
    fi
}

# Start the daemon
start_daemon() {
    ensure_cookie
    write_runtime_info

    # Start the release in foreground mode (systemd will manage daemonization)
    exec "${RELEASE_ROOT}/bin/${RELEASE_NAME}" start
}

# Stop the daemon gracefully
stop_daemon() {
    "${RELEASE_ROOT}/bin/${RELEASE_NAME}" stop
}

# Get daemon status
status_daemon() {
    "${RELEASE_ROOT}/bin/${RELEASE_NAME}" pid
}

# Main command dispatcher
case "$1" in
    start)
        start_daemon
        ;;
    stop)
        stop_daemon
        ;;
    status)
        status_daemon
        ;;
    *)
        echo "Usage: $0 {start|stop|status}"
        exit 1
        ;;
esac
