#!/usr/bin/env bash
# Print only the failing CI contexts for a PR (or a raw SHA).
#
# Usage: fj-pr-failing <pr-number-or-sha>
#
# Output: TAB-separated columns: context<TAB>description<TAB>target_url
# Empty output (exit 0) means no failures.
# Exits 0 always — failures are not script errors, just CI state.

source "$(dirname "$(readlink -f "$0")")/_fj-lib.sh"

ref="${1:-}"
[ -n "$ref" ] || fj_die "usage: fj-pr-failing <pr-number-or-sha>"

if [[ "$ref" =~ ^[0-9]+$ ]]; then
  sha=$(fj_pr_head_sha "$ref")
else
  sha="$ref"
fi

fj_statuses "$sha" \
  | jq -r '.[] | select(.status == "failure" or .status == "error")
                | [.context, .description, .target_url] | @tsv'
