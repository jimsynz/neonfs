#!/usr/bin/env bash
# Open a pull request.
#
# Usage: fj-pr-create <head-branch> <title> <body|-> [base-branch]
#
# Body may be "-" to read from stdin (preferred for multi-line markdown).
# Base branch defaults to "main".
# Prints the new PR number on success.

source "$(dirname "$(readlink -f "$0")")/_fj-lib.sh"

head="${1:-}"
title="${2:-}"
body_arg="${3:-}"
base="${4:-main}"
[ -n "$head" ] && [ -n "$title" ] && [ -n "$body_arg" ] || \
  fj_die "usage: fj-pr-create <head-branch> <title> <body|-> [base-branch]"

if [ "$body_arg" = "-" ]; then
  body=$(cat)
else
  body="$body_arg"
fi

payload=$(jq -nc \
  --arg title "$title" \
  --arg body  "$body" \
  --arg head  "$head" \
  --arg base  "$base" \
  '{title: $title, body: $body, head: $head, base: $base}')

response=$(fj_curl POST "/pulls" --data-binary "$payload")
echo "$response" | jq -r '.number'
