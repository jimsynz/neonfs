FROM harton.dev/james/asdf_container:latest

# Install FUSE support for neonfs_fuse development and testing
# Install systemd for systemd-analyze validation
RUN apt-get update && apt-get install -y \
    libfuse3-dev \
    fuse3 \
    pkg-config \
    systemd \
    && rm -rf /var/lib/apt/lists/*

RUN useradd dev
RUN mkdir /home/dev
RUN mkdir /workdir
RUN chown dev:dev /home/dev
RUN chown dev:dev /workdir
USER dev
ENV HOME=/home/dev
COPY resources/dev_zshrc /home/dev/.zshrc

WORKDIR /workdir
COPY .tool-versions /workdir
RUN /usr/local/bin/asdf_install
RUN curl -fsSL https://claude.ai/install.sh | bash


